' Create settings screen
function CreateSettingsScreen() as Object
    settings = CreateObject("roSGNode", "SettingsView")
    m.global.sceneManager.callFunc("pushScene", settings)
    settings.callFunc("loadSettings")
    return settings
end function

' Create discover screen (Seerr/Overseerr)
function CreateDiscoverPage() as Object
    discover = CreateObject("roSGNode", "DiscoverPage")
    config = m.global.session.user.settings
    if config <> invalid
        discover.serverUrl = chainLookupReturn(config, "discover.serverUrl", "")
        discover.apiKey = chainLookupReturn(config, "discover.apiKey", "")
    end if
    m.global.sceneManager.callFunc("pushScene", discover)
    return discover
end function
