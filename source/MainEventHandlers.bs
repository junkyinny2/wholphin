    else if keyIndex = 17 then ' Play
        ' Toggle play/pause on video player
    else if keyIndex = 18 then ' Pause
        ' Toggle play/pause
    end if
end function

' Handle playback error recovery
function HandlePlaybackError() as Void
    print "[Wholphin] Playback error detected"
    
    ' Try to recover by retrying with transcoding
    queueManager = m.global.queueManager
    if queueManager <> invalid then
        currentItem = queueManager.callFunc("getCurrentItem")
        if currentItem <> invalid then
            ' Force transcode and retry
            queueManager.callFunc("setForceTranscode", true)
            queueManager.callFunc("playCurrentItem")
        end if
    end if
end function

' Handle Quick Connect result
function HandleQuickConnectResult(buttonIndex as Integer) as Void
    if buttonIndex = 0 then
        ' User wants to try quick connect again
        quickConnectData = initQuickConnect()
        if quickConnectData <> invalid then
            code = chainLookupReturn(quickConnectData, ["Code"], "")
            if code <> "" then
                show_dialog(translateText("Quick Connect"), translateText("Enter code: ") + code + translateText(" on your Jellyfin server"))
            end if
        end if
    end if
end function

