' ============================================================
' api.users - User endpoints
' ============================================================
namespace api.users

    function Get() as Object
        req = APIRequest("/Users")
        return getJson(req)
    end function

    function GetMe() as Object
        req = APIRequest("/Users/Me")
        return getJson(req)
    end function

    function GetPublic() as Object
        req = APIRequest("/Users/Public")
        return getJson(req)
    end function

    function AuthenticateByName(username as String, password as String) as Object
        req = APIRequest("/Users/AuthenticateByName")
        body = {
            Username: username
            Pw:       password
        }
        return postJson(req, body)
    end function

    function GetImageURL(userId as String, imageType as String, params = {} as Object) as String
        params.quality = chainLookupReturn(params, ["quality"], "90")
        return buildURL("/Users/" + userId + "/Images/" + imageType, params)
    end function

    function MarkFavorite(itemId as String, userId = "" as String) as Object
        if userId = "" then userId = session.user.GetId()
        req = APIRequest("/Users/" + userId + "/FavoriteItems/" + itemId)
        return postJson(req, {})
    end function

    function UnmarkFavorite(itemId as String, userId = "" as String) as Object
        if userId = "" then userId = session.user.GetId()
        req = APIRequest("/Users/" + userId + "/FavoriteItems/" + itemId)
        return deleteVoid(req)
    end function

    function MarkPlayed(itemId as String, userId = "" as String) as Object
        if userId = "" then userId = session.user.GetId()
        req = APIRequest("/Users/" + userId + "/PlayedItems/" + itemId)
        return postJson(req, {})
    end function

    function UnmarkPlayed(itemId as String, userId = "" as String) as Object
        if userId = "" then userId = session.user.GetId()
        req = APIRequest("/Users/" + userId + "/PlayedItems/" + itemId)
        return deleteVoid(req)
    end function

    function UpdateConfiguration(config as Object) as Object
        req = APIRequest("/Users/" + session.user.GetId() + "/Configuration")
        return postJson(req, config)
    end function

end namespace

' ============================================================
' api.videos - Video streaming endpoints
' ============================================================
namespace api.videos

    function GetAdditionalParts(id as String) as Object
        req = APIRequest("/Videos/" + id + "/AdditionalParts")
        return getJson(req)
    end function

    function GetStreamURL(id as String, container as String, startTimeTicks = 0 as Integer) as String
        params = {
            StartTimeTicks: startTimeTicks
            Static:       "false"
        }
        return buildURL("/Videos/" + id + "/stream." + container, params)
    end function

    function GetSubtitles(id as String, mediaSourceId as String, index as Integer, format as String) as String
        return buildURL("/Videos/" + id + "/" + mediaSourceId + "/Subtitles/" + index.ToStr() + "/" + format)
    end function

    function DeleteSubtitle(id as String, index as Integer) as Object
        req = APIRequest("/Videos/" + id + "/Subtitles/" + index.ToStr())
        return deleteVoid(req)
    end function

end namespace

' ============================================================
' api.subtitles - Subtitle endpoints
' ============================================================
namespace api.subtitles

    function Get(subtitleId as String) as String
        req = CreateObject("roUrlTransfer")
        serverUrl = session.server.GetUrl()
        req.SetUrl(serverUrl + "/Subtitles/" + subtitleId + "/Stream")
        
        ' Add auth header
        req.SetHeaders({
            "Authorization": buildAuthHeader()
        })
        
        return getString(req)
    end function

end namespace

