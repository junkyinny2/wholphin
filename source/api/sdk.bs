' ============================================================
' api.audio - Audio streaming endpoints
' ============================================================
namespace api.audio

    function GetStreamURL(id as String, container as String, audioCodec = "aac" as String, startTimeTicks = 0 as Integer) as String
        serverUrl = session.server.GetUrl()
        params = {
            Container:    container
            AudioCodec:   audioCodec
            StartTimeTicks: startTimeTicks
            Static:       "false"
        }
        url = buildURL("/Audio/" + id + "/stream", params)
        return url
    end function

    function GetStreamURLWithContainer(id as String, container as String, startTimeTicks = 0 as Integer) as String
        serverUrl = session.server.GetUrl()
        params = {
            StartTimeTicks: startTimeTicks
            Static:       "false"
        }
        url = buildURL("/Audio/" + id + "/stream." + container, params)
        return url
    end function

    function GetUniversalURL(id as String, mediaSourceId as String, audioCodec = "aac" as String, maxAudioChannels = 2 as Integer) as String
        params = {
            Id:               id
            MediaSourceId:    mediaSourceId
            AudioCodec:       audioCodec
            MaxAudioChannels: maxAudioChannels
        }
        url = buildURL("/Audio/" + id + "/Universal", params)
        return url
    end function

    function GetLyrics(id as String) as Object
        req = APIRequest("/Audio/" + id + "/Lyrics")
        return getJson(req)
    end function

end namespace

