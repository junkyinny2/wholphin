namespace api.auth

    function GetKeys() as Object
        req = APIRequest("/Auth/Keys")
        return getJson(req)
    end function

    function PostKeys(app as String) as Object
        req = APIRequest("/Auth/Keys")
        return postJson(req, { App: app })
