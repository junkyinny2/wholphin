' ============================================================
' api.items - Item endpoints (core)
' ============================================================
namespace api.items

    function Get(params = {} as Object) as Object
        req = APIRequest("/Items", params)
        return getJson(req)
    end function

    function GetByID(id as String) as Object
        req = APIRequest("/Items/" + id)
        return getJson(req)
    end function

    function GetByFolder(parentId as String, params = {} as Object) as Object
        params.parentId = parentId
        req = APIRequest("/Items", params)
        return getJson(req)
    end function

    function GetChildren(id as String, params = {} as Object) as Object
        req = APIRequest("/Items/" + id + "/Children", params)
        return getJson(req)
    end function

    function GetIntros(id as String) as Object
        req = APIRequest("/Items/" + id + "/Intros")
        return getJson(req)
    end function

    function GetSuggestions(userId = "" as String) as Object
        if userId = "" then userId = session.user.GetId()
        req = APIRequest("/Users/" + userId + "/Suggestions")
        return getJson(req)
    end function

    function GetLatest(userId = "" as String, params = {} as Object) as Object
        if userId = "" then userId = session.user.GetId()
        req = APIRequest("/Users/" + userId + "/Items/Latest", params)
        return getJson(req)
    end function

    function GetFilters(userId = "" as String) as Object
        if userId = "" then userId = session.user.GetId()
        req = APIRequest("/Items/Filters", { userId: userId })
        return getJson(req)
    end function

    function GetFilters2(userId = "" as String, parentId = "" as String) as Object
        if userId = "" then userId = session.user.GetId()
        params = { userId: userId }
        if parentId <> "" then params.parentId = parentId
        req = APIRequest("/Items/Filters2", params)
        return getJson(req)
    end function

    function GetImages(id as String) as Object
        req = APIRequest("/Items/" + id + "/Images")
        return getJson(req)
    end function

    function GetSpecialFeatures(id as String) as Object
        req = APIRequest("/Items/" + id + "/SpecialFeatures")
        return getJson(req)
    end function

    function GetPlaybackInfo(id as String, userId = "" as String) as Object
        if userId = "" then userId = session.user.GetId()
        req = APIRequest("/Items/" + id + "/PlaybackInfo", { userId: userId })
        return getJson(req)
    end function

    function PostPlayBackInfo(id as String, mediaSourceId = "" as String, audioStreamIndex = -1 as Integer, subtitleStreamIndex = -1 as Integer, startTimeTicks = 0 as Integer) as Object
        deviceProfile = getDeviceProfile()
        body = {
            DeviceProfile:    deviceProfile
            MediaSourceId:    mediaSourceId
            AudioStreamIndex: audioStreamIndex
            SubtitleStreamIndex: subtitleStreamIndex
            StartTimeTicks:   startTimeTicks
            AutoOpenLiveStream: true
            EnableDirectPlay: true
            EnableDirectStream: true
            EnableTranscoding: true
            MaxAudioChannels: 6
            UserId:           session.user.GetId()
        }
        req = APIRequest("/Items/" + id + "/PlaybackInfo")
        return postJson(req, body)
    end function

    function GetInstantMix(id as String) as Object
        req = APIRequest("/Items/" + id + "/InstantMix")
        return getJson(req)
    end function

    function GetSimilar(id as String) as Object
        req = APIRequest("/Items/" + id + "/Similar")
        return getJson(req)
    end function

    function GetThemeMedia(id as String) as Object
        req = APIRequest("/Items/" + id + "/ThemeMedia")
        return getJson(req)
    end function

    function GetThemeSongs(id as String, userId = "" as String) as Object
        if userId = "" then userId = session.user.GetId()
        req = APIRequest("/Items/" + id + "/ThemeSongs", { userId: userId })
        return getJson(req)
    end function

    function GetThemeVideos(id as String, userId = "" as String) as Object
        if userId = "" then userId = session.user.GetId()
        req = APIRequest("/Items/" + id + "/ThemeVideos", { userId: userId })
        return getJson(req)
    end function

    function GetCounts(userId = "" as String) as Object
        if userId = "" then userId = session.user.GetId()
        req = APIRequest("/Items/Counts", { userId: userId })
        return getJson(req)
    end function

    function SearchRemoteSubtitles(id as String, language as String) as Object
        req = APIRequest("/Items/" + id + "/RemoteSearch/Subtitles/" + language)
        return getJson(req)
    end function

    function DownloadRemoteSubtitles(id as String, subtitleId as String) as Object
        req = APIRequest("/Items/" + id + "/RemoteSearch/Subtitles/" + subtitleId)
        return postJson(req, {})
    end function

    function GetAncestors(id as String) as Object
        req = APIRequest("/Items/" + id + "/Ancestors")
        return getJson(req)
    end function

end namespace

