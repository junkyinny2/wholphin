' Wholphin Roku - Jellyfin API SDK
' Complete set of API endpoint wrappers organized by namespace

' ============================================================
' Top-level API functions
' ============================================================

' Get user views (libraries)
function GetUserViews(userId = "" as String) as Object
    if userId = "" then userId = session.user.GetId()
    req = APIRequest("/Users/" + userId + "/Views")
    return getJson(req)
end function

