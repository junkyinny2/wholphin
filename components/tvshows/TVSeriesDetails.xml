<?xml version="1.0" encoding="utf-8"?>
<component name="TVSeriesDetails" extends="JFScreen">
  <interface>
    <field id="seriesId" type="string" value="" alwaysNotify="true" />
    <field id="seriesData" type="node" />
    <field id="seasons" type="array" value="" />
    <field id="isFavorite" type="boolean" value="false" />
    <field id="isPlayed" type="boolean" value="false" />
  </interface>

  <children>
    <Poster
      id="seriesBackdrop"
      translation="[0, 0]"
      width="1920"
      height="520"
      loadDisplayMode="scaleToFit" />

    <Rectangle
      id="seriesBackdropOverlay"
      translation="[0, 0]"
      width="1920"
      height="520"
      color="0x00000060" />

    <Poster
      id="seriesPoster"
      translation="[60, 80]"
      width="260"
      height="390"
      loadDisplayMode="scaleToFit" />

    <Label
      id="seriesTitle"
      translation="[360, 80]"
      width="1000"
      height="45"
      font="font:LargeBoldSystemFont"
      color="0xFFFFFFFF"
      text=""
      vertAlign="center" />

    <Label
      id="seriesYear"
      translation="[360, 130]"
      width="200"
      height="30"
      font="font:SmallSystemFont"
      color="0xB0B0B0FF"
      text=""
      vertAlign="center" />

    <Label
      id="seriesRating"
      translation="[570, 130]"
      width="120"
      height="30"
      font="font:SmallSystemFont"
      color="0xFFC107FF"
      text=""
      vertAlign="center" />

    <Label
      id="seriesStatus"
      translation="[700, 130]"
      width="200"
      height="30"
      font="font:SmallSystemFont"
      color="0x00E676FF"
      text=""
      vertAlign="center" />

    <Label
      id="seriesOverview"
      translation="[360, 170]"
      width="1070"
      height="120"
      font="font:SmallSystemFont"
      color="0xB0B0B0FF"
      text=""
      wrap="true"
      vertAlign="top" />

    <Group id="seriesActionButtons" translation="[360, 310]">
      <JFButton id="btnPlayNext" translation="[0, 0]" buttonText="Play Next" width="180" />
      <JFButton id="btnResumeSeries" translation="[200, 0]" buttonText="Resume" width="160" visible="false" />
      <JFButton id="btnShuffle" translation="[380, 0]" buttonText="Shuffle" width="160" />
      <JFButton id="btnFavSeries" translation="[560, 0]" buttonText="Favorite" width="160" />
      <JFButton id="btnMyListSeries" translation="[740, 0]" buttonText="My List" width="160" />
    </Group>

    <Group id="seriesContentSection" translation="[0, 530]">
      <Label
        id="seasonsLabel"
        translation="[60, 20]"
        width="300"
        height="30"
        font="font:MediumBoldSystemFont"
        color="0xFFFFFFFF"
        text="Seasons" />

      <TVSeasonGrid
        id="seasonGrid"
        translation="[60, 60]"
        width="1800"
        height="350"
        visible="true" />

      <!-- Cast -->
      <Label
        id="seriesCastLabel"
        translation="[60, 430]"
        width="300"
        height="30"
        font="font:MediumBoldSystemFont"
        color="0xFFFFFFFF"
        text="Cast"
        visible="false" />

      <MarkupGrid
        id="seriesCastGrid"
        translation="[60, 470]"
        width="1800"
        height="200"
        itemComponentName="CastItem"
        itemSize="[150, 200]"
        itemSpacing="[10, 0]"
        numColumns="10"
        numRows="1"
        visible="false" />
    </Group>
  </children>

  <script type="text/brightscript" uri="pkg:/components/tvshows/TVSeriesDetails.bs" />
</component>
