<?xml version="1.0" encoding="utf-8"?>
<component name="TVSeasonDetails" extends="JFScreen">
  <interface>
    <field id="seriesData" type="node" alwaysNotify="true" />
    <field id="seasonData" type="node" alwaysNotify="true" />
    <field id="episodes" type="array" value="" />
  </interface>

  <children>
    <Poster
      id="seasonBackdrop"
      translation="[0, 0]"
      width="1920"
      height="300"
      loadDisplayMode="scaleToFit" />

    <Rectangle
      id="seasonBackdropOverlay"
      translation="[0, 0]"
      width="1920"
      height="300"
      color="0x00000060" />

    <Poster
      id="seasonPoster"
      translation="[60, 30]"
      width="160"
      height="240"
      loadDisplayMode="scaleToFit" />

    <Label
      id="seasonTitle"
      translation="[260, 30]"
      width="1000"
      height="40"
      font="font:LargeBoldSystemFont"
      color="0xFFFFFFFF"
      text=""
      vertAlign="center" />

    <Label
      id="seasonEpisodeCount"
      translation="[260, 75]"
      width="300"
      height="25"
      font="font:SmallSystemFont"
      color="0xB0B0B0FF"
      text=""
      vertAlign="center" />

    <Label
      id="seasonOverview"
      translation="[260, 110]"
      width="1070"
      height="80"
      font="font:SmallSystemFont"
      color="0xB0B0B0FF"
      text=""
      wrap="true"
      vertAlign="top" />

    <Group id="seasonActionButtons" translation="[260, 210]">
      <JFButton id="btnPlayAll" translation="[0, 0]" buttonText="Play All" width="160" />
      <JFButton id="btnShuffleSeason" translation="[180, 0]" buttonText="Shuffle" width="160" />
    </Group>

    <TVEpisodeList
      id="episodeList"
      translation="[0, 310]"
      width="1920"
      height="770"
      visible="true" />
  </children>

  <script type="text/brightscript" uri="pkg:/components/tvshows/TVSeasonDetails.bs" />
</component>
