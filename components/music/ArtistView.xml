<?xml version="1.0" encoding="utf-8"?>
<component name="ArtistView" extends="JFScreen">
  <interface>
    <field id="artist" type="node" alwaysNotify="true" />
    <field id="albums" type="array" value="" />
    <field id="isFavorite" type="boolean" value="false" />
  </interface>

  <children>
    <Poster
      id="artistBackdrop"
      translation="[0, 0]"
      width="1920"
      height="400"
      loadDisplayMode="scaleToFit" />

    <Rectangle
      id="artistOverlay"
      translation="[0, 0]"
      width="1920"
      height="400"
      color="0x00000060" />

    <Poster
      id="artistImage"
      translation="[60, 60]"
      width="280"
      height="280"
      loadDisplayMode="scaleToFit" />

    <Label
      id="artistName"
      translation="[380, 80]"
      width="1000"
      height="45"
      font="font:LargeBoldSystemFont"
      color="0xFFFFFFFF"
      text=""
      vertAlign="center" />

    <Label
      id="artistBio"
      translation="[380, 140]"
      width="1070"
      height="150"
      font="font:SmallSystemFont"
      color="0xB0B0B0FF"
      text=""
      wrap="true"
      vertAlign="top" />

    <Group id="artistActionButtons" translation="[380, 310]">
      <JFButton id="btnArtistShuffle" translation="[0, 0]" buttonText="Shuffle" width="160" />
      <JFButton id="btnArtistFavorite" translation="[180, 0]" buttonText="Favorite" width="160" />
    </Group>

    <Group id="artistContent" translation="[0, 420]">
      <Label
        id="albumsLabel"
        translation="[60, 20]"
        width="300"
        height="30"
        font="font:MediumBoldSystemFont"
        color="0xFFFFFFFF"
        text="Albums" />

      <MarkupGrid
        id="albumsGrid"
        translation="[60, 60]"
        width="1800"
        height="560"
        itemComponentName="GridItemMedium"
        itemSize="[290, 340]"
        itemSpacing="[15, 15]"
        numColumns="6"
        numRows="2" />
    </Group>
  </children>

  <script type="text/brightscript" uri="pkg:/components/music/ArtistView.bs" />
</component>
