' Wholphin Roku - Home item component

sub Init()
    m.poster = m.top.findNode("itemPoster")
    m.checkmark = m.top.findNode("playedCheckmark")
    m.label = m.top.findNode("itemLabel")
    m.focusIndicator = m.top.findNode("focusIndicator")
    
    m.top.observeField("itemContent", "onItemContentChange")
    m.top.observeField("focusedChild", "onFocusChange")
end sub

sub onFocusChange()
    hasFocus = m.top.hasFocus()
    if m.focusIndicator <> invalid then
        m.focusIndicator.visible = hasFocus
    end if
end sub

sub onItemContentChange()
    content = m.top.itemContent
    if content = invalid then return
    
    title = content.title
    if title = invalid then title = ""
    
    url = content.HDPosterUrl
    if url <> invalid and url <> "" then
        m.poster.uri = url
    end if
    
    m.top.itemTitle = title
    m.label.text = title
    
    itemType = content.type
    if itemType = invalid then itemType = ""
    m.top.itemType = itemType
    
    userData = chainLookupReturn(content, ["json", "UserData"], {})
    played = chainLookupReturn(userData, ["Played"], false)
    m.top.watched = played
    m.checkmark.visible = played
end sub
