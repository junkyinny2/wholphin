<?xml version="1.0" encoding="utf-8"?>
<component name="Home" extends="JFScreen">
  <interface>
    <field id="libraries" type="array" value="" />
    <field id="heroItems" type="array" value="" />
    <field id="rowItems" type="array" value="" />
    <field id="backdropUrl" type="string" value="" />
  </interface>
  
  <children>
    <!-- Background fill (visible when no backdrop is loaded) -->
    <Rectangle
      id="bgFill"
      translation="[0, 0]"
      width="1920"
      height="1080"
      color="0x1A1A2EFF" />
    
    <!-- Backdrop image -->
    <Poster
      id="backdrop"
      translation="[0, 0]"
      width="1920"
      height="1080"
      loadDisplayMode="scaleToFit"
      visible="true"
      uri="pkg:/images/roku_logo.png" />
    
    <!-- Transition backdrop for cross-fade -->
    <Poster
      id="backdropTransition"
      translation="[0, 0]"
      width="1920"
      height="1080"
      loadDisplayMode="scaleToFit"
      visible="false"
      opacity="0" />
    
    <!-- Hero banner at the top -->
    <HeroBanner
      id="heroBanner"
      translation="[0, 60]"
      visible="true" />
    
    <!-- Loading indicator -->
    <Label
      id="loadingLabel"
      translation="[860, 250]"
      width="200"
      height="40"
      font="font:MediumSystemFont"
      color="0xFFFFFFFF"
      text="Loading..."
      horizAlign="center"
      vertAlign="center"
      visible="true" />

    <!-- Home screen content rows -->
    <HomeRows
      id="homeRows"
      translation="[100, 460]"
      visible="true" />
    
    <!-- Options slider (side panel) -->
    <Group id="optionsSlider" translation="[1920, 100]" visible="false">
      <Rectangle
        width="400"
        height="980"
        color="0x16213EFF" />
    </Group>
  </children>
  
  <script type="text/brightscript" uri="pkg:/components/home/Home.bs" />
</component>
