<?xml version="1.0" encoding="utf-8"?>
<component name="JFServer" extends="Group">
  <interface>
    <field id="serverInfo" type="node" alwaysNotify="true" />
    <field id="serverName" type="string" value="" />
    <field id="serverUrl" type="string" value="" />
    <field id="serverVersion" type="string" value="" />
    <field id="isConnected" type="boolean" value="false" />
    <field id="selected" type="boolean" value="false" />
  </interface>

  <children>
    <Rectangle
      id="serverBg"
      width="800"
      height="80"
      color="0x16213EFF" />

    <Label
      id="serverNameLabel"
      translation="[20, 10]"
      width="500"
      height="30"
      font="font:MediumBoldSystemFont"
      color="0xFFFFFFFF"
      text=""
      vertAlign="center" />

    <Label
      id="serverUrlLabel"
      translation="[20, 45]"
      width="500"
      height="25"
      font="font:SmallestSystemFont"
      color="0x707070FF"
      text=""
      vertAlign="center" />

    <Label
      id="serverVersionLabel"
      translation="[600, 20]"
      width="180"
      height="40"
      font="font:SmallSystemFont"
      color="0xB0B0B0FF"
      text=""
      horizAlign="right"
      vertAlign="center" />
  </children>

  <script type="text/brightscript" uri="pkg:/components/config/JFServer.bs" />
</component>
