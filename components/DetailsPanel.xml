<?xml version="1.0" encoding="utf-8"?>
<component name="DetailsPanel" extends="Group">
  <interface>
    <field id="itemData" type="assocarray" alwaysNotify="true" />
    <field id="focusedButton" type="int" value="-1" alwaysNotify="true" />
  </interface>

  <children>
    <!-- Poster image -->
    <Poster
      id="detailPoster"
      translation="[0, 0]"
      width="260"
      height="390"
      loadDisplayMode="scaleToFit" />

    <!-- Title -->
    <Label
      id="detailTitle"
      translation="[300, 20]"
      width="800"
      height="45"
      font="font:LargeBoldSystemFont"
      color="0xFFFFFFFF"
      vertAlign="center" />

    <!-- Year -->
    <Label
      id="detailYear"
      translation="[300, 70]"
      width="100"
      height="30"
      font="font:SmallSystemFont"
      color="0xB0B0B0FF"
      vertAlign="center" />

    <!-- Runtime -->
    <Label
      id="detailRuntime"
      translation="[410, 70]"
      width="100"
      height="30"
      font="font:SmallSystemFont"
      color="0xB0B0B0FF"
      vertAlign="center" />

    <!-- Description -->
    <Paragraph
      id="detailDescription"
      translation="[300, 110]"
      width="800"
      height="160"
      font="font:SmallSystemFont"
      color="0xB0B0B0FF"
      vertAlign="top" />

    <!-- Progress bar background -->
    <Rectangle
      id="progressBarBg"
      translation="[300, 280]"
      width="600"
      height="6"
      color="0x444444FF" />

    <!-- Progress bar fill -->
    <Rectangle
      id="progressBarFill"
      translation="[300, 280]"
      width="0"
      height="6"
      color="0x00A4DCFF" />

    <!-- Play button -->
    <Group
      id="playButton"
      translation="[300, 310]">
      <Rectangle
        id="playBtnBg"
        width="160"
        height="50"
        color="0x00A4DCFF" />
      <Label
        id="playBtnLabel"
        translation="[40, 10]"
        width="80"
        height="30"
        font="font:SmallSystemFont"
        color="0xFFFFFFFF"
        horizAlign="center"
        vertAlign="center"
        text="Play" />
    </Group>

    <!-- Resume button -->
    <Group
      id="resumeButton"
      translation="[480, 310]">
      <Rectangle
        id="resumeBtnBg"
        width="160"
        height="50"
        color="0x444444FF" />
      <Label
        id="resumeBtnLabel"
        translation="[30, 10]"
        width="100"
        height="30"
        font="font:SmallSystemFont"
        color="0xFFFFFFFF"
        horizAlign="center"
        vertAlign="center"
        text="Resume" />
    </Group>
  </children>

  <script type="text/brightscript" uri="pkg:/components/DetailsPanel.brs" />
</component>
