{
  "files": [
    "manifest",
    "source/**/*.*",
    "components/**/*.*",
    "images/**/*.*",
    "locale/**/*.*",
    "settings/*.*"
  ],
  "plugins": [],
  "diagnosticFilters": ["node_modules/**/*", "**/roku_modules/**/*"],
  "sourceMap": true,
  "autoImportComponentScript": true,
  "stagingFolderPath": "build/staging",
  "retainStagingFolder": false,
  "outFile": "out/Wholphin.zip",
  "diagnosticSeverityOverrides": {
    "BS1128": "hint",
    "BS1104": "hint",
    "BS1079": "hint"
  }
}
